{
  "name": "sublime-merge",
  "displayName": "Sublime Merge",
  "version": "1.3.4",
  "description": "Open files in Sublime Merge (locally patched fork: worktree + Command Palette support)",
  "categories": [
    "SCM Providers"
  ],
  "repository": "https://github.com/adhamu/history-in-sublime-merge.git",
  "license": "MIT",
  "author": {
    "name": "adhamu"
  },
  "publisher": "local",
  "main": "./out/extension.js",
  "scripts": {
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --format=cjs --minify --outfile=out/extension.js",
    "typecheck": "tsc -p ./ --noEmit",
    "vscode:prepublish": "npm run bundle"
  },
  "contributes": {
    "commands": [
      {
        "command": "sublime-merge.openRepository",
        "title": "Open repository in Sublime Merge",
        "category": "Sublime Merge"
      },
      {
        "command": "sublime-merge.viewFileHistory",
        "title": "View File History in Sublime Merge",
        "category": "Sublime Merge"
      },
      {
        "command": "sublime-merge.viewLineHistory",
        "title": "View Line History in Sublime Merge",
        "category": "Sublime Merge"
      },
      {
        "command": "sublime-merge.blameFile",
        "title": "Blame File in Sublime Merge",
        "category": "Sublime Merge"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sublime-merge.viewFileHistory",
          "group": "YourGroup@1"
        },
        {
          "command": "sublime-merge.blameFile",
          "group": "YourGroup@3"
        }
      ],
      "editor/context": [
        {
          "command": "sublime-merge.viewFileHistory",
          "group": "YourGroup@1"
        },
        {
          "command": "sublime-merge.viewLineHistory",
          "group": "YourGroup@2"
        },
        {
          "command": "sublime-merge.blameFile",
          "group": "YourGroup@3"
        }
      ]
    },
    "configuration": [
      {
        "title": "Sublime Merge",
        "properties": {
          "sublime-merge.path": {
            "type": "string",
            "markdownDescription": "Path to Sublime Merge. When not set, the default path, depending on the operating system, is used."
          }
        }
      }
    ]
  },
  "activationEvents": [
    "onCommand:sublime-merge.openRepository",
    "onCommand:sublime-merge.viewFileHistory",
    "onCommand:sublime-merge.viewLineHistory",
    "onCommand:sublime-merge.blameFile"
  ],
  "devDependencies": {
    "@types/node": "^14.14.25",
    "@types/vscode": "1.53.0",
    "esbuild": "^0.24.0",
    "typescript": "^4.1.3"
  },
  "engines": {
    "vscode": "^1.53.0"
  },
  "icon": "sublime-merge.png"
}
