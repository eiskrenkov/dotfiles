[core]
	excludesfile = ~/.gitignore

[user]
	name = Egor Iskrenkov
	email = egor@iskrenkov.me
	signingkey = ~/.ssh/personal.pub

[init]
	defaultBranch = master

[http]
	lowSpeedLimit = 1
	lowSpeedTime = 1800

[gpg]
  format = ssh

[commit]
  gpgsign = true

[rerere]
  enabled = true
  # automatically solve conflict if rebasing on a branch with a lot of new commits
  autoUpdate = true
