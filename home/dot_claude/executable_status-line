#!/usr/bin/env bash

# Reads Claude Code context window JSON from stdin and renders a visual status bar.
# Output:
#   [██████░░░░] 63% - ctx | [██░░░░░░░░] 20% - 5h usage (resets 4pm) | [█░░░░░░░░░] 10% - 7d usage
#   Model Name | session_id

input=$(cat)

dim='\033[2;37m'
rst='\033[0m'

make_bar() {
  local pct=$1
  local filled=$(( pct * 10 / 100 ))
  local empty=$(( 10 - filled ))
  local color
  if [ "$pct" -le 50 ]; then
    color="$dim"
  elif [ "$pct" -le 75 ]; then
    color='\033[0;33m'
  else
    color='\033[0;31m'
  fi
  local filled_str="" empty_str=""
  for (( i=0; i<filled; i++ )); do filled_str="${filled_str}█"; done
  for (( i=0; i<empty;  i++ )); do empty_str="${empty_str}░"; done
  printf "${dim}[${rst}${color}%s${rst}${dim}%s]${rst}" "$filled_str" "$empty_str"
}

# --- Line 1: All progress bars ---
ctx_used=$(echo "$input" | jq -r '.context_window.used_percentage // 0')
ctx_pct=$(printf "%.0f" "$ctx_used")
ctx_bar=$(make_bar "$ctx_pct")

five_used=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage // empty')
five_resets_at=$(echo "$input" | jq -r '.rate_limits.five_hour.resets_at // empty')
week_used=$(echo "$input" | jq -r '.rate_limits.seven_day.used_percentage // empty')

parts=()
parts+=("$(printf '%s %b%s%% - ctx%b' "$ctx_bar" "$dim" "$ctx_pct" "$rst")")

if [ -n "$five_used" ]; then
  pct=$(printf "%.0f" "$five_used")
  bar=$(make_bar "$pct")
  reset_str=""
  if [ -n "$five_resets_at" ]; then
    reset_str=$(printf ' (resets %s)' "$(date -r "$five_resets_at" '+%-I%p' | tr '[:upper:]' '[:lower:]')")
  fi
  parts+=("$(printf '%s %b%s%% - 5h usage%s%b' "$bar" "$dim" "$pct" "$reset_str" "$rst")")
fi

if [ -n "$week_used" ]; then
  pct=$(printf "%.0f" "$week_used")
  bar=$(make_bar "$pct")
  parts+=("$(printf '%s %b%s%% - 7d usage%b' "$bar" "$dim" "$pct" "$rst")")
fi

result="${parts[0]}"
for (( i=1; i<${#parts[@]}; i++ )); do
  result+=$(printf ' %b|%b %s' "$dim" "$rst" "${parts[$i]}")
done
printf '%s' "$result"

# --- Line 2: Model & session ---
model=$(echo "$input" | jq -r '.model.display_name // .model // "unknown"')
session=$(echo "$input" | jq -r '.session_id // "no-session"')
printf '\n%b%s | %s%b' "$dim" "$model" "$session" "$rst"
