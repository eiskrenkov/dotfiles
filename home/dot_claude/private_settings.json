{
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "pop monitor set-status $TMUX_PANE needs_attention 2>/dev/null || true",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/eiskrenkov/.claude/hooks/rtk-rewrite.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "pop monitor set-status $TMUX_PANE working 2>/dev/null || true",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "pop monitor register $TMUX_PANE 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "pop monitor set-status $TMUX_PANE needs_attention 2>/dev/null || true",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "pop monitor set-status $TMUX_PANE working 2>/dev/null || true",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(bundle exec rubocop:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec tds-danger run:*)",
      "Bash(bundle exec rails runner:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "mcp__atlassian__getjiraissue",
      "mcp__atlassian__getaccessibleatlassianresources",
      "Bash(xargs:*)",
      "Bash(ls:*)",
      "Bash(bin/rails zeitwerk:check)",
      "Bash(git ls-tree:*)",
      "Bash(bundle exec ruby:*)",
      "Bash(bundle exec rake:*)",
      "Bash(bundle info:*)",
      "Bash(bundle show:*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/status-line",
    "type": "command"
  }
}
