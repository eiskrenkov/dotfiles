# window style
# Inactive panes are dimmed (muted grey fg) so the focused pane stands out by
# brightness rather than by border colour — necessary because every pane's
# border is now tinted with its own chip colour (see tmux_conf_theme_pane_border
# below), which removes the focused/unfocused distinction from the border alone.
# tmux has no true opacity; fading the foreground is the terminal equivalent.
# Bg stays "default" so full-screen apps in inactive panes aren't recoloured.
tmux_conf_theme_window_fg="$tmux_conf_theme_colour_3"   # muted grey
tmux_conf_theme_window_bg="default"

# highlight focused pane, possible values are:
#   - true
#   - false (default)
# Enabled so the active pane gets its own (full-brightness) style instead of
# inheriting the dimmed window style above.
tmux_conf_theme_highlight_focused_pane=true

# focused pane colours: pin the active pane to the bright white theme colour
# (not "default" — the terminal default renders greyish here, which dimmed the
# active pane too) so its text looks exactly as it did before the dimming.
tmux_conf_theme_focused_pane_fg="$tmux_conf_theme_colour_7"   # white
tmux_conf_theme_focused_pane_bg="default"

# pane border style, possible values are:
#   - thin (default)
#   - fat
tmux_conf_theme_pane_border_style=thin

# pane borders colours:
# Every pane's border matches that pane's own label-chip colour (@pane_color,
# set per pane by scripts/pane-color.sh) so each frame shares a hue with its
# chip — active and inactive alike. Copy-mode (yellow) and synchronize-panes
# (red) still take precedence on the active border, and panes without a colour
# yet fall back to neutral grey (inactive) / blue (active). Because active and
# inactive borders now carry the same colour, focus is shown by dimming the
# inactive panes' contents instead (see tmux_conf_theme_window_fg above).
tmux_conf_theme_pane_border="#{?@pane_color,#{@pane_color},$tmux_conf_theme_colour_2}"
tmux_conf_theme_pane_active_border="#{?@pane_color,#{@pane_color},$tmux_conf_theme_colour_4}"
%if #{>=:#{version},3.2}
tmux_conf_theme_pane_active_border="#{?pane_in_mode,$tmux_conf_theme_colour_9,#{?synchronize-panes,$tmux_conf_theme_colour_16,#{?@pane_color,#{@pane_color},$tmux_conf_theme_colour_4}}}"
%endif

