# status line style
# bg is Ghostty's own default background (#282c34, from `ghostty +show-config
# --default`) rather than the dark colour_1 fill. This makes the bar blend
# seamlessly with the terminal — visually "no background" — while still being a
# concrete colour, which matters because Oh my tmux! bakes this value into the
# fg of the powerline window separators (the  triangles): with bg=default those
# triangles resolve to the terminal *foreground* and render as mismatched blocks;
# with a concrete colour they blend. If you change Ghostty's theme, update this
# (and the two matching bg=#282c34 in status-format[1] below) to the new bg.
tmux_conf_theme_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_status_bg="#282c34"
tmux_conf_theme_status_attr="none"

# terminal title
#   - built-in variables are:
#     - #{circled_window_index}
#     - #{circled_session_name}
#     - #{hostname}
#     - #{hostname_ssh}
#     - #{hostname_full}
#     - #{hostname_full_ssh}
#     - #{username}
#     - #{username_ssh}
tmux_conf_theme_terminal_title="#S"

# window status style
#   - built-in variables are:
#     - #{circled_window_index}
#     - #{circled_session_name}
#     - #{hostname}
#     - #{hostname_ssh}
#     - #{hostname_full}
#     - #{hostname_full_ssh}
#     - #{username}
#     - #{username_ssh}
tmux_conf_theme_window_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_window_status_bg="#282c34"   # Ghostty default bg — blends the bar & powerline separators (see status-style note)
tmux_conf_theme_window_status_attr="none"
# Window title shows what its active pane is doing — not the window name (#W,
# auto-set to whatever ran last = noise) nor a bare pane count. The label is the
# active pane's @pane_cmd: the *bare* command identity, with the path/branch
# prefix that the pane chip carries stripped off. It is set by fish on each
# prompt (conf.d/pane_label.fish) and overridden to just the Claude session name
# by the pane-name hook (~/.claude/hooks/pane-name.sh), so a claude pane reads as
# "fix-tmux-labels" rather than "claude | fix-tmux-labels". When no long-running
# command occupies the pane, @pane_cmd is unset and we fall back to the live
# #{pane_current_command}. If the window holds more than one pane, " +N" reports
# how many *other* panes it has (window_panes - 1). tmux re-evaluates the format
# on every status redraw — and split/kill/focus force an immediate redraw — so
# the label, the count, and the active-pane selection all track live.
tmux_conf_theme_window_status_format="#I. #{?@pane_cmd,#{@pane_cmd},#{pane_current_command}}#{?#{>:#{window_panes},1}, +#{e|-:#{window_panes},1},}#{?#{||:#{window_bell_flag},#{window_zoomed_flag}}, ,}#{?window_bell_flag,!,}#{?window_zoomed_flag,Z,}"
#tmux_conf_theme_window_status_format="#I #{window_panes} panes#{?#{||:#{window_bell_flag},#{window_zoomed_flag}}, ,}#{?window_bell_flag,!,}#{?window_zoomed_flag,Z,}"
#tmux_conf_theme_window_status_format="#{circled_window_index} #W#{?#{||:#{window_bell_flag},#{window_zoomed_flag}}, ,}#{?window_bell_flag,!,}#{?window_zoomed_flag,Z,}"
#tmux_conf_theme_window_status_format="#I #W#{?#{||:#{window_bell_flag},#{window_zoomed_flag}}, ,}#{?window_bell_flag,🔔,}#{?window_zoomed_flag,🔍,}"

