# -- per-pane labels & colours -------------------------------------------------
# A label chip along the top border of every pane, so panes stay distinguishable
# across many splits. The chip text comes from the per-pane user option
# @pane_label and its colour from @pane_color:
#   - @pane_label: set by fish to "<short cwd> → ⎇ <branch> → <cmd>" on each
#     prompt (see conf.d/pane_label.fish), with " | <name>" appended by the
#     Claude Code pane-name Stop hook (see ~/.claude/hooks/pane-name.sh). It
#     carries embedded tmux #[…] styles per segment (path plain, branch italic,
#     <cmd> bold, claude name italic at regular weight) so the info types read
#     distinctly; the #[default] at the end of pane-border-format below clears
#     them off the chip. When the pane is shelled into a Kubernetes pod
#     (`kubectl exec`/`attach`, or the `k-goto`/`kg` helper's exec/console), the
#     <cmd> segment becomes a distinct blue "☸ <pod-or-connection-key>" badge
#     instead, so a remote pod session is never mistaken for a local shell.
#   - @pane_color: a random hex palette colour assigned to each pane on creation
#     (see scripts/pane-color.sh). fish also reads it to tint the prompt
#     chevrons to match the chip (see functions/fish_prompt.fish).
# Until those are set, the chip falls back to the running command name on a
# neutral colour. Dark text stays legible because the palette is all bright.
set -g pane-border-status top
set -g pane-border-format " #[fg=colour232,bg=#{?@pane_color,#{@pane_color},colour245}] #{?@pane_label,#{@pane_label},#{pane_current_command}} #[default]"

# assign a random label colour to every newly created pane
set-hook -g after-new-session  "run-shell -b \"~/.config/tmux/scripts/pane-color.sh '#{pane_id}'\""
set-hook -g after-new-window   "run-shell -b \"~/.config/tmux/scripts/pane-color.sh '#{pane_id}'\""
set-hook -g after-split-window "run-shell -b \"~/.config/tmux/scripts/pane-color.sh '#{pane_id}'\""

# -- dismiss Claude Code notifications on pane focus ---------------------------
# The Claude Code Notification hook raises a Hammerspoon notification tagged with
# the pane that needs attention (see ~/.claude/hooks/notify.sh and
# ~/.hammerspoon/init.lua). Clicking it jumps to that pane — but reaching the
# pane by navigating in tmux should dismiss it just the same. pane-focus-in fires
# whenever a pane gains focus (select-pane / select-window / switch-client, and
# returning to Ghostty), so we hand the now-focused pane's id to Hammerspoon,
# which withdraws that pane's pending notice (a no-op when there is none). Needs
# focus-events so the terminal actually reports focus changes to tmux.
set -g focus-events on
set-hook -g pane-focus-in "run-shell -b \"~/.config/tmux/scripts/claude-notify-clear.sh '#{pane_id}'\""

# -- second status line: all sessions ----------------------------------------
# A row beneath the window list that lists every session the way the row above
# lists windows. With status-position at the bottom (the default), status-format[0]
# is the existing windows line and status-format[1] renders directly below it.
# Oh my tmux!'s apply logic only sets status-left/right and window-status-*, never
# the line count or status-format, so this survives a reload.
#
# #{S:...} (tmux >= 3.0) loops over every session. The attached session is
# highlighted like the current window — dark text on the blue chip (colour_4
# #00afff) — and the rest are muted grey (colour_3 #8a8a8a) on the Ghostty
# default bg (#282c34), matching the first line. #{client_session} is the
# session the *rendering* client is
# on, so the highlight stays correct per client. "·N" appends the window count
# when a session has more than one, mirroring the " +N" pane count on the window
# row above. Commas inside #{?...} are escaped as #, since comma is its argument
# separator; colours are literal hex because the $tmux_conf_theme_colour_N shell
# vars aren't in scope for raw tmux commands (same as pane-border-format above).
set -g status 2
set -g status-format[1] "#[fg=#8a8a8a,bg=#282c34,align=left] #{S:#{?#{==:#{session_name},#{client_session}},#[fg=#080808#,bg=#00afff#,bold] #{session_name}#{?#{>:#{session_windows},1},·#{session_windows},} #[default#,fg=#8a8a8a#,bg=#282c34],#[fg=#8a8a8a] #{session_name}#{?#{>:#{session_windows},1},·#{session_windows},} }}"

# pop — popup pickers that switch the tmux session via switch-client.
bind-key -r p display-popup -E -w 90% -h 60% "pop select"
bind-key -r o display-popup -E -w 90% -h 60% "pop worktree --switch"
bind-key -r i display-popup -E -w 90% -h 60% "pop dashboard"

{{ if .tds -}}
# Pair the Cursor editor (left half of the screen) to the active project so it
# follows when you switch projects with pop. This lives on a hook, not chained
# off the picker bindings: chaining ran sync-cursor.sh every time the picker
# closed — even on Esc with no selection — and before switch-client had resolved
# the new path. client-session-changed fires only on an *actual* session switch,
# with #{pane_current_path} already pointing at the new project. Appended at a
# high index so it coexists with pop's own client-session-changed hook (which
# clears pane status) rather than clobbering it. Work machine only (.tds).
# See scripts/sync-cursor.sh.
set-hook -g 'client-session-changed[100]' "run-shell -b \"~/.config/tmux/scripts/sync-cursor.sh '#{pane_current_path}'\""
{{ end -}}

# prefix + P (Ghostty cmd+shift+p): command palette — an fzf modal listing the
# rich, easy-to-forget features in these dotfiles (smart checkout, ports, open
# in Sublime Merge / Cursor, …), sorted by recency of use, with each feature's
# matching keybind shown. The registry lives in command_palette.fish; selecting
# a row runs the exact same command/script the feature's keybind would. The
# palette only *picks*; the dispatcher (started in the background first, since
# tmux runs commands chained after display-popup immediately rather than on
# close) waits for the choice, lets the popup close, then runs it — so
# interactive fzf tools and popups never nest inside the palette's own popup.
bind-key P run-shell -b "~/.config/tmux/scripts/palette-dispatch.sh '#{pane_id}' '#{pane_current_path}'" \; display-popup -E -w 70% -h 70% -d "#{pane_current_path}" "fish -c command_palette"

# reload — override Oh my tmux!'s stock prefix + r so the keybind and the command
# palette's "reload" entry share one source: the tmux-reload fish function, the
# exact same code path the palette invokes, so the two can't drift.
bind -N "Reload the tmux configuration" r run-shell -b "fish -c 'tmux-reload \"#{pane_current_path}\"'"

# lazygit
bind g display-popup -d "#{pane_current_path}" -h 90% -w 90% -E "lazygit"

# prefix + l (Ghostty cmd+l): browse the git log in an fzf popup — runs the glo
# fish function. CMD_PALETTE_POPUP=1 makes glo use plain fzf instead of its
# floating "fzf --tmux" popup, which would try to nest a second popup inside this
# one. NB: keep shell command-substitution syntax out of this file's comments.
# oh-my-tmux reloads via "cut -c3- tmux.conf.local | sh", which strips the
# leading "# " and executes every line, so command substitution written in a
# comment actually runs on reload (this very line once opened a stray fzf). This is
# the exact invocation the command palette's "browse commit log" entry uses (see
# palette-dispatch.sh), so the keybind and the palette can't drift. Overrides Oh
# my tmux!'s stock prefix + l (last-window).
bind l display-popup -E -d "#{pane_current_path}" -w 90% -h 80% -e CMD_PALETTE_POPUP=1 "fish -c glo"

# scroll pane up/down (triggered from ghostty's cmd+up / cmd+down)
bind-key -r < copy-mode -u
bind-key -r > if -F '#{pane_in_mode}' 'send-keys -X scroll-down'

bind '"' split-window -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"
bind U split-window -vb -c "#{pane_current_path}"
bind L split-window -hb -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"
bind & kill-window # Disable confirmation
bind x kill-pane # Disable confirmation

# Don't exit from tmux when closing a session
set -g detach-on-destroy off

# -- tpm -----------------------------------------------------------------------

# while I don't use tpm myself, many people requested official support so here
# is a seamless integration that automatically installs plugins in parallel

# whenever a plugin introduces a variable to be used in 'status-left' or
# 'status-right', you can use it in 'tmux_conf_theme_status_left' and
# 'tmux_conf_theme_status_right' variables.

# by default, launching tmux will update tpm and all plugins
#   - true (default)
#   - false
tmux_conf_update_plugins_on_launch=true

# by default, reloading the configuration will update tpm and all plugins
#   - true (default)
#   - false
tmux_conf_update_plugins_on_reload=true

# by default, reloading the configuration will uninstall tpm and plugins when no
# plugins are enabled
#   - true (default)
#   - false
tmux_conf_uninstall_plugins_on_reload=true

# /!\ the tpm bindings differ slightly from upstream:
#   - installing plugins: <prefix> + I
#   - uninstalling plugins: <prefix> + Alt + u
#   - updating plugins: <prefix> + u

# /!\ do not add set -g @plugin 'tmux-plugins/tpm'
# /!\ do not add run '~/.tmux/plugins/tpm/tpm'

# to enable a plugin, use the 'set -g @plugin' syntax:
# visit https://github.com/tmux-plugins for available plugins
#set -g @plugin 'tmux-plugins/tmux-copycat'
#set -g @plugin 'tmux-plugins/tmux-cpu'
#set -g @plugin 'tmux-plugins/tmux-resurrect'
#set -g @plugin 'tmux-plugins/tmux-continuum'
#set -g @continuum-restore 'on'


# -- custom key bindings -------------------------------------------------------

# prefix + M (Ghostty cmd+shift+m): open Sublime Merge for the active pane's
# git repository, if it is one. Runs the open-in-sublime-merge fish function —
# the exact same code path the command palette invokes, so the two can't drift.
bind -N "Open Sublime Merge for the current pane's repo" M run-shell -b "fish -c 'open-in-sublime-merge \"#{pane_current_path}\"'"

# prefix + E (Ghostty cmd+shift+e): open/focus Cursor for the active pane's
# project — a manual counterpart to the pop-picker sync (same sync-cursor.sh).
bind -N "Open/focus Cursor for the current pane's project" E run-shell -b "~/.config/tmux/scripts/sync-cursor.sh '#{pane_current_path}'"

# prefix + K (Ghostty cmd+shift+k): open the active pane's git repo on GitHub in
# the browser, if it is one. Runs the open-in-github fish function — the exact
# same code path the command palette invokes, so the two can't drift.
bind -N "Open the current pane's repo on GitHub" K run-shell -b "fish -c 'open-in-github \"#{pane_current_path}\"'"


