initial-command = /bin/zsh -l -i -c "tmux new-session -A -s main"
command         = /bin/zsh -l -i -c "tmux new-session -A -s main"

confirm-close-surface = false

window-colorspace = display-p3
macos-icon = holographic

font-family = "TX-02"
font-size    = 14
font-thicken = true

mouse-hide-while-typing = true

# Send ^B + c on Cmd+T
keybind = cmd+t=text:\x02c

# Send ^B + N on Cmd+N to switch tmux windows by index.
# Bind the PHYSICAL digit keys (digit_N) so these override Ghostty's built-in
# cmd+digit_N=goto_tab defaults — otherwise those intercept Cmd+1..9 and switch
# Ghostty tabs instead of reaching tmux.
keybind = cmd+digit_1=text:\x021
keybind = cmd+digit_2=text:\x022
keybind = cmd+digit_3=text:\x023
keybind = cmd+digit_4=text:\x024
keybind = cmd+digit_5=text:\x025
keybind = cmd+digit_6=text:\x026
keybind = cmd+digit_7=text:\x027
keybind = cmd+digit_8=text:\x028
keybind = cmd+digit_9=text:\x029

# Send ^B + " on Cmd+Shift+D
keybind = cmd+shift+d=text:\x02\"

# Send ^B + % on Cmd+Shift+R
keybind = cmd+shift+r=text:\x02%

# Send ^B + U on Cmd+Shift+U (split up)
keybind = cmd+shift+u=text:\x02U

# Send ^B + L on Cmd+Shift+L (split left)
keybind = cmd+shift+l=text:\x02L

# Send ^B + z on Cmd+Shift+Enter
keybind = cmd+shift+enter=text:\x02z

# Send ^B + x on Cmd+W
keybind = cmd+w=text:\x02x

# Send ^B + p on Cmd+p
keybind = cmd+p=text:\x02p

# Send ^B + o on Cmd+o
keybind = cmd+o=text:\x02o

# Send ^B + i on Cmd+i
keybind = cmd+i=text:\x02i

# Send ^B + Shift + P on Cmd+Shift+P
keybind = cmd+shift+p=text:\x02P

# Send ^B + u on Cmd+U
keybind = cmd+u=text:\x02u

# Send ^B + g on Cmd+G
keybind = cmd+g=text:\x02g

# Send ^B + ESC [A on Cmd+Shift+Up
keybind = cmd+shift+up=text:\x02\x1B[A

# Send ^B + ESC [C on Cmd+Shift+Right
keybind = cmd+shift+right=text:\x02\x1B[C

# Send ^B + ESC [B on Cmd+Shift+Down
keybind = cmd+shift+down=text:\x02\x1B[B

# Send ^B + ESC [D on Cmd+Shift+Left
keybind = cmd+shift+left=text:\x02\x1B[D

# Send ^B + < on Cmd+Up (scroll tmux pane up)
keybind = cmd+up=text:\x02<

# Send ^B + > on Cmd+Down (scroll tmux pane down)
keybind = cmd+down=text:\x02>

# Send ^B + M on Cmd+Shift+M (open Sublime Merge for the current pane's repo)
keybind = cmd+shift+m=text:\x02M

# Send ^B + E on Cmd+Shift+E (open/focus Cursor for the current pane's project)
keybind = cmd+shift+e=text:\x02E
